{
  "name": "demo-facturator",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "dev": "PATH=\"$PWD:$PATH\" turbo dev",
    "build": "PATH=\"$PWD:$PATH\" turbo build",
    "lint": "PATH=\"$PWD:$PATH\" turbo lint",
    "typecheck": "PATH=\"$PWD:$PATH\" turbo typecheck",
    "test": "PATH=\"$PWD:$PATH\" turbo test",
    "dev:web": "corepack pnpm --filter web dev",
    "dev:api": "corepack pnpm --filter api dev",
    "db:generate": "corepack pnpm --filter @demo-facturator/database db:generate",
    "db:migrate": "corepack pnpm --filter @demo-facturator/database db:migrate",
    "db:seed": "corepack pnpm --filter @demo-facturator/database db:seed"
  },
  "devDependencies": {
    "eslint": "^9.22.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.2"
  }
}
